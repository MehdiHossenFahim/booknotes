<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>BookNotes</title>
    <link rel="stylesheet" href="/styles/main.css">
</head>

<body>

    <header>
        <h1>📚 BookNotes</h1>

        <!-- ADD BOOK FORM -->
        <form action="/add" method="post" class="form">

            <input type="text" name="searchBook" placeholder="Book title" required>

            <input type="number" name="rating" placeholder="Rating (1-10)" min="1" max="10" required>

            <button type="submit">Add</button>
        </form>

        <!-- SORTING -->
        <div class="sort">
            <a href="/?sort=rating">Top Rated</a>
            <a href="/?sort=title">Title</a>
            <a href="/">Newest</a>
        </div>
    </header>

    <main class="container">

        <% books.forEach(book=> { %>

            <div class="book-card">

                <!-- FULL COVER (no cropping) -->
                <img src="<%= book.cover_url %>" alt="cover">

                <div class="book-info">

                    <h2>
                        <%= book.title %>
                    </h2>
                    <p>Author: <%= book.author %>
                    </p>
                    <p>⭐ <%= book.rating %>/10</p>

                    <!-- DELETE -->
                    <form action="/delete/<%= book.id %>" method="post">
                        <button class="delete-btn">Delete</button>
                    </form>

                </div>
            </div>

            <% }) %>

                <% if (books.length===0) { %>
                    <p>No books added yet.</p>
                    <% } %>

    </main>

</body>

</html>